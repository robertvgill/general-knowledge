import { k8sCall } from "../profiles.js";
import { resolveNamespace } from "../routing.js";
import { pooled, parallelMap } from "../concurrency.js";

const PH = { headers: { "Content-Type": "application/merge-patch+json" } };

function stripContainer(c, removeReqs) {
  if (!c || !c.resources) return false;
  let changed = false;
  if (c.resources.limits && Object.keys(c.resources.limits).length > 0) {
    c.resources.limits = null;
    changed = true;
  }
  if (removeReqs && c.resources.requests && Object.keys(c.resources.requests).length > 0) {
    c.resources.requests = null;
    changed = true;
  }
  return changed;
}

function auditAndStrip(templateSpec, removeReqs) {
  const withLimits    = [];
  const withoutLimits = [];
  let   changed       = false;

  const TYPES = [
    { field: "containers",           label: "container" },
    { field: "initContainers",       label: "initContainer" },
    { field: "ephemeralContainers",  label: "sidecar" },
  ];

  for (const t of TYPES) {
    for (const c of (templateSpec[t.field] || [])) {
      const hasLimits = c.resources && c.resources.limits && Object.keys(c.resources.limits).length > 0;
      if (hasLimits) {
        withLimits.push({
          type:   t.label,
          name:   c.name,
          limits: JSON.parse(JSON.stringify(c.resources.limits)),
          requests: c.resources && c.resources.requests ? JSON.parse(JSON.stringify(c.resources.requests)) : null
        });
        if (stripContainer(c, removeReqs)) changed = true;
      } else {
        withoutLimits.push({ type: t.label, name: c.name });
      }
    }
  }

  return { withLimits: withLimits, withoutLimits: withoutLimits, changed: changed };
}

function hasAnyLimits(templateSpec) {
  const all = []
    .concat(templateSpec.containers          || [])
    .concat(templateSpec.initContainers      || [])
    .concat(templateSpec.ephemeralContainers || []);
  return all.some(function(c) {
    return c.resources && c.resources.limits && Object.keys(c.resources.limits).length > 0;
  });
}

async function resolveNamespaces(pattern, clients) {
  if (!pattern.includes("*") && !pattern.includes("?")) return [pattern];
  const r = await k8sCall(function() { return clients.core.listNamespace({}); });
  if (!r.success || !r.data) return [pattern];
  const rx = new RegExp("^" + pattern.replace(/\*/g, ".*").replace(/\?/g, ".") + "$");
  return (r.data.items || [])
    .map(function(n) { return n.metadata.name; })
    .filter(function(n) { return rx.test(n); });
}

async function processController(clients, nsName, kind, item, dryRun, removeReqs, podNameFilter) {
  const name         = item.metadata.name;
  const templateSpec = item.spec && item.spec.template && item.spec.template.spec;
  if (!templateSpec) return null;

  if (podNameFilter) {
    const matchLabels = (item.spec.selector && item.spec.selector.matchLabels) || {};
    const sel = Object.entries(matchLabels).map(function(e) { return e[0] + "=" + e[1]; }).join(",");
    if (sel) {
      const pr = await k8sCall(function() { return clients.core.listNamespacedPod({ namespace: nsName, labelSelector: sel }); });
      const names = (pr.success && pr.data && pr.data.items || []).map(function(p) { return p.metadata.name; });
      if (!names.includes(podNameFilter)) return null;
    }
  }

  if (!hasAnyLimits(templateSpec)) {
    return { ns: nsName, name: name, kind: kind, status: "no-limits", found: [] };
  }

  const workingSpec = JSON.parse(JSON.stringify(templateSpec));
  const audit       = auditAndStrip(workingSpec, removeReqs);

  if (!audit.changed) {
    return { ns: nsName, name: name, kind: kind, status: "no-limits", withLimits: [], withoutLimits: audit.withoutLimits };
  }

  if (dryRun) {
    return { ns: nsName, name: name, kind: kind, status: "would-patch", withLimits: audit.withLimits, withoutLimits: audit.withoutLimits };
  }

  const body = { spec: { template: { spec: workingSpec } } };
  let result;

  if (kind === "Deployment")
    result = await pooled(function() { return k8sCall(function() { return clients.apps.patchNamespacedDeployment({ name: name, namespace: nsName, body: body }, undefined, undefined, undefined, undefined, undefined, undefined, PH); }); });
  else if (kind === "StatefulSet")
    result = await pooled(function() { return k8sCall(function() { return clients.apps.patchNamespacedStatefulSet({ name: name, namespace: nsName, body: body }, undefined, undefined, undefined, undefined, undefined, undefined, PH); }); });
  else if (kind === "DaemonSet")
    result = await pooled(function() { return k8sCall(function() { return clients.apps.patchNamespacedDaemonSet({ name: name, namespace: nsName, body: body }, undefined, undefined, undefined, undefined, undefined, undefined, PH); }); });
  else if (kind === "DeploymentConfig")
    result = await pooled(function() { return k8sCall(function() { return clients.custom.patchNamespacedCustomObject("apps.openshift.io", "v1", nsName, "deploymentconfigs", name, body, undefined, undefined, undefined, PH); }); });

  return {
    ns:             nsName,
    name:           name,
    kind:           kind,
    status:         result.success ? "patched" : "error",
    withLimits:     audit.withLimits,
    withoutLimits:  audit.withoutLimits,
    error:          result.success ? null : result.output
  };
}

async function processNamespace(nsName, clients, podNameFilter, dryRun, removeReqs) {
  const [deplR, stsR, dsR, dcR] = await Promise.all([
    k8sCall(function() { return clients.apps.listNamespacedDeployment({ namespace: nsName }); }),
    k8sCall(function() { return clients.apps.listNamespacedStatefulSet({ namespace: nsName }); }),
    k8sCall(function() { return clients.apps.listNamespacedDaemonSet({ namespace: nsName }); }),
    k8sCall(function() { return clients.custom.listNamespacedCustomObject("apps.openshift.io", "v1", nsName, "deploymentconfigs"); }),
  ]);

  const fetchErrors = [];
  if (!deplR.success) fetchErrors.push("Deployment list failed: " + deplR.output);
  if (!stsR.success)  fetchErrors.push("StatefulSet list failed: " + stsR.output);
  if (!dsR.success)   fetchErrors.push("DaemonSet list failed: " + dsR.output);

  const controllers = [];
  for (const d of (deplR.data && deplR.data.items || [])) controllers.push({ kind: "Deployment",       item: d });
  for (const s of (stsR.data  && stsR.data.items  || [])) controllers.push({ kind: "StatefulSet",      item: s });
  for (const d of (dsR.data   && dsR.data.items   || [])) controllers.push({ kind: "DaemonSet",        item: d });
  for (const d of (dcR.data   && dcR.data.items   || [])) controllers.push({ kind: "DeploymentConfig", item: d });

  const results = await parallelMap(controllers, function(c) {
    return processController(clients, nsName, c.kind, c.item, dryRun, removeReqs, podNameFilter);
  });

  return results.filter(function(r) { return r !== null; });
}

export async function handleRemoveResourceLimits(args) {
  const namespaceArg = args.namespace;
  const podNameArg   = args.podName        || null;
  const dryRun       = args.dryRun         || false;
  const removeReqs   = args.removeRequests || false;

  const firstNs    = namespaceArg.replace(/\*/g, "a");
  const firstRoute = resolveNamespace(firstNs);
  const { getK8sClients } = await import("../profiles.js");
  const clients    = getK8sClients(firstRoute.profile);

  const namespaces = await resolveNamespaces(namespaceArg, clients);
  if (!namespaces.length) return { content: [{ type: "text", text: "No namespaces matched: " + namespaceArg }] };

  const nestedResults = await parallelMap(namespaces, function(nsName) {
    return processNamespace(nsName, clients, podNameArg, dryRun, removeReqs);
  });
  const all = nestedResults.reduce(function(a, r) { return a.concat(r); }, []);

  const patched    = all.filter(function(r) { return r.status === "patched"; });
  const wouldPatch = all.filter(function(r) { return r.status === "would-patch"; });
  const noLimits   = all.filter(function(r) { return r.status === "no-limits"; });
  const errors     = all.filter(function(r) { return r.status === "error"; });

  const target = dryRun ? wouldPatch : patched;
  const action = dryRun ? "would be patched" : "patched";

  const lines = [];
  lines.push((dryRun ? "[DRY RUN] " : "") + "Remove Resource Limits — " + namespaceArg);
  lines.push("Scanned " + all.length + " controllers across " + namespaces.length + " namespace(s).");
  lines.push("");

  if (target.length === 0) {
    lines.push("No resource limits found. Nothing to " + (dryRun ? "patch" : "remove") + ".");
  } else {
    lines.push((dryRun ? "The following would be patched:" : "The following were patched:"));
    lines.push("");
    target.forEach(function(r) {
      const total    = (r.withLimits || []).length + (r.withoutLimits || []).length;
      const limited  = (r.withLimits || []).length;
      lines.push(r.kind + ": " + r.name + "  (" + limited + "/" + total + " containers have limits)");
      (r.withLimits || []).forEach(function(f) {
        lines.push("  - [" + f.type + "] " + f.name + " — LIMITS: cpu=" + (f.limits.cpu || "-") + ", memory=" + (f.limits.memory || "-") + (f.requests ? "  requests: cpu=" + (f.requests.cpu || "-") + ", memory=" + (f.requests.memory || "-") : ""));
      });
      (r.withoutLimits || []).forEach(function(f) {
        lines.push("  - [" + f.type + "] " + f.name + " — no limits");
      });
    });
  }

  if (errors.length) {
    lines.push("");
    lines.push("Errors (" + errors.length + "):");
    errors.forEach(function(r) { lines.push("  - " + r.kind + "/" + r.name + ": " + r.error); });
  }

  if (noLimits.length) {
    lines.push("");
    lines.push(noLimits.length + " controller(s) had no limits set.");
  }

  if (dryRun && target.length > 0) {
    lines.push("");
    lines.push("No actual changes were made. Run without dryRun to apply.");
  }

  return { content: [{ type: "text", text: lines.join("\n") }] };
}
